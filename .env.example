# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ai_governance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_governance

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:4000/api
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Ollama LLM (local AI for PDF report generation)
# WSL users: run `export OLLAMA_HOST=0.0.0.0 && ollama serve` before starting Docker
#OLLAMA_URL=https://brain.gammaingenieros.com/v1/chat/completions
OLLAMA_URL=http://host.docker.internal:11434/v1/chat/completions
OLLAMA_MODEL=deepseek-r1:8b
# OLLAMA_MODEL=qwen2.5:27b
OLLAMA_TIMEOUT_MS=300000
