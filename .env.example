# ============================================================
# GAMMA AI GOVERNANCE ASSESSMENT PLATFORM — Environment Config
# Copia este archivo a .env y ajusta los valores
# ============================================================

# --- Base de datos (para desarrollo local sin Docker) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ai_governance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_governance

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# --- Google OAuth (opcional) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Backend ---
PORT=4000
NODE_ENV=development
# Orígenes permitidos para CORS (dev local: 5173=Vite, 3000=Docker frontend)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend ---
# Con Docker: dejar /api para que nginx haga el proxy al backend (funciona local y en servidor)
# Con Vite dev server: cambiar a http://localhost:4000/api
VITE_API_URL=/api
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ============================================================
# LLM PROVIDER — elige UNA opción
# ============================================================

# --- Opción 1: Ollama local (por defecto) ---
# macOS/Linux: ollama serve  |  WSL: export OLLAMA_HOST=0.0.0.0 && ollama serve
OLLAMA_URL=http://host.docker.internal:11434/v1/chat/completions
OLLAMA_MODEL=deepseek-r1:8b
LLM_API_KEY=

# --- Opción 2: Google AI Studio (Gemini) ---
# 1. Obtén una key en https://aistudio.google.com/apikey
# 2. Descomenta las tres líneas siguientes y comenta las de Ollama
# OLLAMA_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# OLLAMA_MODEL=gemini-2.0-flash
# LLM_API_KEY=tu-api-key-de-google-ai-studio

# Timeout para llamadas al LLM (ms) — Google AI Studio suele responder en <30s
OLLAMA_TIMEOUT_MS=120000
